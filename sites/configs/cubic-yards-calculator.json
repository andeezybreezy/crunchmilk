  "howItWorks": {
    "intro": "A cubic yard is 3 feet &times; 3 feet &times; 3 feet = 27 cubic feet. This calculator converts dimensions in any unit to cubic yards for any common shape.",
    "rules": [
      "Rectangle: Length &times; Width &times; Depth. Cylinder: &pi; &times; (diameter/2)&sup2; &times; height",
      "Triangle: &frac12; &times; base &times; height &times; depth. Trapezoid: &frac12; &times; (top + bottom) &times; height &times; length",
      "All measurements are converted to feet first, then the result in cubic feet is divided by 27 for cubic yards"
    ],
    "outro": "This is a universal volume calculator. Use it for concrete, gravel, mulch, soil, sand, or any bulk material sold by the cubic yard. For material-specific calculations with weight and cost estimates, use our dedicated calculators."
  },
  "faq": [
    {
      "question": "How many cubic feet are in a cubic yard?",
      "answer": "There are exactly 27 cubic feet in one cubic yard. A cubic yard is 3 feet long, 3 feet wide, and 3 feet tall (3 x 3 x 3 = 27). To convert cubic feet to cubic yards, divide by 27."
    },
    {
      "question": "How do I calculate cubic yards from inches?",
      "answer": "Convert all measurements to feet first (divide inches by 12), then multiply length x width x depth to get cubic feet, then divide by 27 for cubic yards. Or use our calculator above — it handles unit conversion automatically."
    },
    {
      "question": "How much area does a cubic yard cover?",
      "answer": "One cubic yard covers: 324 sq ft at 1 inch deep, 162 sq ft at 2 inches, 108 sq ft at 3 inches, 81 sq ft at 4 inches, or 54 sq ft at 6 inches deep. The depth determines how far a cubic yard spreads."
    },
    {
      "question": "How many wheelbarrows are in a cubic yard?",
      "answer": "A standard 3-cubic-foot wheelbarrow holds about 1/9 of a cubic yard, so 9 wheelbarrow loads equal one cubic yard. A large 6-cubic-foot wheelbarrow takes about 5 loads. This is useful for estimating labor when moving material by hand."
    },
    {
      "question": "What weighs more — a yard of gravel or a yard of mulch?",
      "answer": "Gravel is much heavier. One cubic yard of gravel weighs 2,500-3,000 lbs. One cubic yard of mulch weighs 400-800 lbs. Concrete weighs about 4,000 lbs per yard, soil about 2,000-2,200 lbs, and sand about 2,700 lbs."
    },
    {
      "question": "How many cubic yards fit in a pickup truck?",
      "answer": "A full-size pickup truck bed holds about 2 cubic yards of mulch, 1 cubic yard of soil, or 0.5-1 cubic yard of gravel or stone (limited by weight, not volume). Never exceed your truck's payload rating — check the sticker on the driver's door jamb."
    }
